# Generated by theme-switch — do not edit. Active theme: ${theme_name}
# Self-contained styling block: tmux config variables are file-scoped, so the
# color definitions and every line that uses them must live in this one file.
# source-file'd from ~/.tmux.conf.

# Palette
RED="#${red}"
GREEN="#${green}"
YELLOW="#${yellow}"
BLUE="#${blue}"
MAGENTA="#${purple}"
CYAN="#${accent}"
BLACK="#${bg0}"
DARK_GRAY="#${bg1}"
LIGHT_GRAY="#${bg2}"
MUTED="#${bg3}"
BG="#${bg0}"
FG="#${fg1}"
INACTIVE_FG="#${dim}"

# Nerdfont characters - powerline caps + status icons
HALF_ROUND_OPEN="#(printf '\uE0B6')"
HALF_ROUND_CLOSE="#(printf '\uE0B4')"
TRIANGLE_OPEN="#(printf '\uE0B2')"
TRIANGLE_CLOSE="#(printf '\uE0B0')"
ICON_SESSION="#(printf '\uF120')"
ICON_HOST="#(printf '\uF108')"
ICON_CLOCK="#(printf '\uF017')"
ICON_ZOOM="#(printf '\uF0B2')"

# Move statusbar to the top
set-option -g status-position top

# Basic colors of the Statusbar
set-option -g status-style bg=${BG},fg=${FG}

# Show the window list centered between the left and the right section
set-option -g status-justify centre

# Left: session pill (frost-cyan text + icon; turns yellow while the prefix key is held)
set-option -g status-left "\
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_OPEN}\
#[bg=${LIGHT_GRAY},fg=#{?client_prefix,${YELLOW},${CYAN}},bold] ${ICON_SESSION} #S \
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_CLOSE}\
"

# Right: host pill + clock pill
set-option -g status-right "\
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_OPEN}\
#[bg=${LIGHT_GRAY},fg=${BLUE}] ${ICON_HOST} #h \
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_CLOSE}\
#[bg=default] \
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_OPEN}\
#[bg=${LIGHT_GRAY},fg=${CYAN}] ${ICON_CLOCK} %H:%M \
#[fg=${LIGHT_GRAY},bg=default]${HALF_ROUND_CLOSE}\
"

# Set max length of left and right section
set-option -g status-left-length 100
set-option -g status-right-length 100

# Inactive windows - muted text, no pill
set-option -g window-status-format "#[fg=${MUTED}] #I #W "

# Active window - bright frost-cyan pill, dark bold text (mirrors the waybar active workspace)
set-option -g window-status-current-format "\
#[fg=${CYAN},bg=default]${HALF_ROUND_OPEN}\
#[bg=${CYAN},fg=${BLACK},bold] #I #W#{?window_zoomed_flag, ${ICON_ZOOM},} \
#[fg=${CYAN},bg=default]${HALF_ROUND_CLOSE}\
"

# No extra separator between window items
set-option -g window-status-separator ""

# Pane borders - frost-cyan active border to match the active-window accent
set -g pane-border-lines heavy
set -g pane-border-style "fg=${LIGHT_GRAY}"
set -g pane-active-border-style "fg=${CYAN}"
set -g pane-border-status top
set -g pane-border-format " #P "

# Dim inactive panes so the focused pane stands out (text only — adding a bg here
# makes tmux paint pane backgrounds, which kills ghostty's transparency).
set -g window-style "fg=${INACTIVE_FG}"
set -g window-active-style "fg=${FG}"
