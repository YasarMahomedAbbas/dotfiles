# VSCode Dark Modern — the neutral-grey surfaces and signature #569cd6 blue of
# VS Code's default dark theme. Transparency is kept (you wanted it) even though
# the real editor is opaque.
theme_name=vscode-dark

# Surfaces — neutral greys
bg0=1f1f1f
bg1=252526
bg2=2d2d2d
bg3=383838

# Text
fg0=ffffff
fg1=cccccc
fg2=808080

# Accents
accent=569cd6
accent2=4fc1ff
blue=569cd6
teal=4ec9b0
red=f14c4c
orange=ce9178
yellow=dcdcaa
green=6a9955
purple=c586c0

# Misc roles
muted=3c3c3c
# Readable muted foreground for unfocused tmux panes
dim=808080

# Terminal surface treatment
opacity=0.9
blur=true

# 16-slot ANSI palette — VS Code's default integrated-terminal colors
ansi0=000000
ansi1=cd3131
ansi2=0dbc79
ansi3=e5e510
ansi4=2472c8
ansi5=bc3fbc
ansi6=11a8cd
ansi7=e5e5e5
ansi8=666666
ansi9=f14c4c
ansi10=23d18b
ansi11=f5f543
ansi12=3b8eea
ansi13=d670d6
ansi14=29b8db
ansi15=e5e5e5
