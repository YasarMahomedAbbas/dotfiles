# Nord — the original palette (https://www.nordtheme.com/)
# Hex values are stored WITHOUT a leading '#'; templates add the right prefix
# (#rrggbb, 0xAARRGGBB, rgb(), …) per app. Sourced by theme-switch.
theme_name=nord

# Surfaces — darkest → most elevated (Nord Polar Night)
bg0=2e3440
bg1=3b4252
bg2=434c5e
bg3=4c566a

# Text — bright / normal / muted (Nord Snow Storm + nord3)
fg0=eceff4
fg1=d8dee9
fg2=4c566a

# Accents
accent=88c0d0
accent2=5e81ac
blue=81a1c1
teal=8fbcbb
red=bf616a
orange=d08770
yellow=ebcb8b
green=a3be8c
purple=b48ead

# Misc roles
muted=616e88
# Readable muted foreground for unfocused tmux panes (brighter than fg2, which
# is reserved for waybar's intentionally-faint inactive workspaces).
dim=6c7a96

# Terminal surface treatment
opacity=0.75
blur=true

# 16-slot ANSI palette (terminal colors)
ansi0=3b4252
ansi1=bf616a
ansi2=a3be8c
ansi3=ebcb8b
ansi4=81a1c1
ansi5=b48ead
ansi6=88c0d0
ansi7=e5e9f0
ansi8=4c566a
ansi9=bf616a
ansi10=a3be8c
ansi11=ebcb8b
ansi12=81a1c1
ansi13=b48ead
ansi14=8fbcbb
ansi15=eceff4
