# Dark Nord — Nord's accents kept, Polar Night backgrounds shifted down to the
# near-black ghostty background (#0a0b0e). The Frost/Aurora accents actually pop
# harder on black, so they're unchanged from the original Nord palette.
theme_name=dark-nord

# Surfaces — near-black base, then a *visible* grey ramp. These double as the
# powerline-pill / panel backgrounds (starship, waybar, tmux), so they must read
# against bg0 rather than collapse into it.
bg0=0a0b0e
bg1=1b1f27
bg2=29303c
bg3=3a4150

# Text — Snow Storm kept; muted brightened so it stays legible on black
fg0=eceff4
fg1=d8dee9
fg2=60697d

# Accents — identical to Nord
accent=88c0d0
accent2=5e81ac
blue=81a1c1
teal=8fbcbb
red=bf616a
orange=d08770
yellow=ebcb8b
green=a3be8c
purple=b48ead

# Misc roles
muted=3b4252
# Readable muted foreground for unfocused tmux panes (legible on near-black)
dim=6c7a96

# Terminal surface treatment — slightly less transparent so the black reads as black
opacity=0.85
blur=true

# 16-slot ANSI palette — darker blacks (0/8), Nord accents otherwise
ansi0=1b1f27
ansi1=bf616a
ansi2=a3be8c
ansi3=ebcb8b
ansi4=81a1c1
ansi5=b48ead
ansi6=88c0d0
ansi7=d8dee9
ansi8=3a4150
ansi9=bf616a
ansi10=a3be8c
ansi11=ebcb8b
ansi12=81a1c1
ansi13=b48ead
ansi14=8fbcbb
ansi15=eceff4
