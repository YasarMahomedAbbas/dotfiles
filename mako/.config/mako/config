# Mako notification daemon
# Reload with: makoctl reload
# Colors are theme-driven: `theme-switch` generates ~/.config/theme/mako.conf
# and the include below pulls them in (criteria sections merge by selector, so
# the timeouts/sizing here stay while the colors come from the theme).

font=JetBrainsMono Nerd Font 10

# Position
anchor=bottom-center
margin=20
layer=overlay

# Sizing
width=380
height=140
padding=14
border-size=2
border-radius=10

# Behavior
default-timeout=5000
ignore-timeout=0
max-visible=4
sort=-time
icons=1
max-icon-size=48
markup=1
actions=1

# Theme colors (background/text/border/progress + per-urgency accents)
include=/home/dracul/.config/theme/mako.conf

[urgency=low]
default-timeout=3000

[urgency=high]
default-timeout=0
border-size=3

[app-name=tmux]
default-timeout=4000
