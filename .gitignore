# Nvim lazy lockfile (machine-specific, regenerated automatically)
nvim/.config/nvim/lazy-lock.json

# Tmux plugins (installed by TPM automatically)
tmux/.tmux/plugins/

# Fish machine-specific / auto-generated state (written into the symlinked dir at runtime)
fish/.config/fish/fish_variables
fish/.config/fish/conf.d/
fish/.config/fish/completions/
fish/.config/fish/generated_completions/
fish/.config/fish/fish_history
